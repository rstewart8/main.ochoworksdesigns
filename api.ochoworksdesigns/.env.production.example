# Production API environment for /var/www/ochoworksdesigns/api.ochoworksdesigns/.env

ENV=production
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=ochoworksdesigns
DB_USER=ochoworks_api
DB_PASSWORD=replace-with-strong-password

API_BASE_URL=https://api.ochoworksdesigns.com
API_KEY=replace-with-strong-api-key
DEBUG=false

APP_BASE_URL=https://ochoworksdesigns.com
APP_POST_DEFAULT_IMAGE=/assets/images/featured-plans/modern-farmhouse-plan-1075.jpg

EMAIL_API_KEY=replace-me
CONTACT_EMAIL=randy@ochoworksdesigns.com
FROM_EMAIL=noreply@ochoworksdesigns.com
FROM_NAME=OchoWorks Designs
DEV_EMAIL=randystewart8@gmail.com
REPLY_TO_EMAIL=randy@ochoworksdesigns.com

RECAPTCHA_SECRET_KEY=replace-me

LOGGERPATH=/var/log/ochoworksdesigns/logger.log
ERRORPATH=/var/log/ochoworksdesigns/error.log

JWT_SECRET=replace-with-strong-jwt-secret
ADMIN_ROLE_ID=1

SITEMAP_FILE_PATH=/var/www/web/public/sitemap.xml
TRACKING_URL=https://api.ochoworksdesigns.com

# options: mailtrap, sendgrid
EMAIL_PROVIDER=sendgrid
MAILTRAP_INBOX_ID=
