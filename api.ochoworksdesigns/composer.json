{
    "name": "ochoworksdesigns/api-project",
    "description": "OchoWorks Designs API project",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "firebase/php-jwt": "^6.10"
    },
    "require-dev": {
        
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}